{
    "name": "wiiu-vault",
    "version": "0.1.4",
    "repository": "https://github.com/qwell/wiiu-vault",
    "author": "Jason Parker",
    "license": "GPL-3.0-or-later",
    "main": "dist/index.js",
    "type": "module",
    "typings": "dist/index.d.ts",
    "files": [
        "dist/"
    ],
    "engines": {
        "node": ">=24.0.0"
    },
    "packageManager": "yarn@4.14.1",
    "scripts": {
        "lint": "eslint --cache --cache-strategy metadata --cache-location ./.cache/eslint .",
        "format": "prettier --write --cache --cache-strategy metadata --cache-location ./.cache/prettier .",
        "hygiene": "yarn format && yarn lint",
        "clean": "rimraf dist/ release/ .cache/",
        "build": "tsx scripts/build.ts",
        "start": "tsx scripts/start.ts",
        "start:raw": "yarn build && APP_ROOT=\"$PWD/dist\" node dist/server/index.js",
        "test": "vitest run",
        "release": "yarn clean && yarn build && tsx scripts/release.ts all",
        "release:stage": "yarn clean && yarn build && tsx scripts/release.ts stage",
        "release:zip": "tsx scripts/release.ts zip",
        "generate:titles": "tsx scripts/generate-titles.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/node24": "^24.0.4",
        "@types/adm-zip": "^0.5.8",
        "@types/eslint": "^9.6.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.7.0",
        "@types/prettier": "^3.0.0",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.59.3",
        "@yarnpkg/sdks": "^3.2.3",
        "adm-zip": "^0.5.17",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3",
        "typescript-eslint-language-service": "^5.0.5",
        "vite": "^7.3.3",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "csv-parse": "^6.2.1",
        "express": "^5.2.1",
        "fast-xml-parser": "^5.8.0",
        "open": "^11.0.0",
        "ws": "^8.20.1"
    }
}
