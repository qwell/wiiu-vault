{
    "name": "wiiu-vault",
    "version": "0.1.0",
    "repository": "https://github.com/qwell/wiiu-vault",
    "author": "Jason Parker",
    "license": "GPLv3",
    "main": "dist/index.js",
    "type": "module",
    "typings": "dist/index.d.ts",
    "files": [
        "dist/"
    ],
    "engines": {
        "node": ">=24.0.0"
    },
    "packageManager": "yarn@4.13.0",
    "scripts": {
        "lint": "eslint --cache --cache-strategy metadata --cache-location ./.cache/eslint src/ tests/",
        "format": "prettier --write --cache --cache-strategy metadata --cache-location ./.cache/prettier .",
        "clean": "rimraf dist/ .cache/",
        "build": "tsx scripts/build.ts",
        "start": "tsx scripts/start.ts",
        "test": "vitest run",
        "convert:wiiutdb": "tsx scripts/convert.ts",
        "generate:titles": "bash scripts/generate-titles.sh",
        "generate:titles:node": "tsx scripts/generate-titles.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tsconfig/node24": "^24.0.4",
        "@types/eslint": "^9.6.1",
        "@types/express": "^5",
        "@types/node": "^24.12.2",
        "@types/prettier": "^3.0.0",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@yarnpkg/sdks": "^3.2.3",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.2",
        "typescript-eslint-language-service": "^5.0.5",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    },
    "dependencies": {
        "csv-parse": "^6.2.1",
        "express": "^5.2.1",
        "fast-xml-parser": "^5.7.1"
    }
}
