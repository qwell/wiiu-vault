{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "tsBuildInfoFile": ".cache/.tsbuildinfo.server",
        "types": ["vitest/importMeta", "node"]
    },
    "include": ["src/server/**/*.ts", "src/shared/**/*.ts"]
}
